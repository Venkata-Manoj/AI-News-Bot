# Telegram (use bot token and chat ID)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-bot:v1.0 (by u/yourusername)

# ========== LLM PROVIDERS ==========
# At least one required. Configure multiple for fallback.

# Gemini (Primary - 1000 RPD free)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17

# OpenRouter (Free via various providers)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Groq (Fast inference - free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (Local - no API key needed)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1

# LM Studio (Local - no API key needed)
LMSTUDIO_ENDPOINT=http://localhost:1234/v1
LMSTUDIO_MODEL=llama-3.1-8b-instruct

# Provider fallback order
LLM_PROVIDER_ORDER=gemini,openrouter,groq,ollama,lmstudio

# ========== SOURCE OPTIONS ==========
ENABLE_RSS=true
ENABLE_REDDIT=true
ENABLE_HN=true
ENABLE_ARXIV=true
ENABLE_GITHUB=false

# Hacker News search tag
HN_TAG=ai

# ========== SETTINGS ==========
FETCH_INTERVAL_MINUTES=30
MIN_RELEVANCE_SCORE=6
BATCH_SIZE=5
MAX_ARTICLES_PER_RUN=10
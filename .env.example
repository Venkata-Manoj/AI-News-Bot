# Telegram (use bot token and chat ID)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# If api.telegram.org is blocked, use a proxy URL
# TELEGRAM_API_URL=https://your-worker.workers.dev
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# Apify Token (optional, for Twitter/Reddit)
APIFY_API_KEY=

# ========== LLM PROVIDERS ==========
# At least one required. Configure multiple for fallback.

# Gemini (Primary)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA (secondary)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# OpenRouter (Free via various providers)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Groq (Fast inference - free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (Local - no API key needed)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# LM Studio (Local - no API key needed)
LMSTUDIO_ENDPOINT=http://localhost:1234/v1
LMSTUDIO_MODEL=llama-3.1-8b-instruct

# Provider fallback order
LLM_PROVIDER_ORDER=gemini,nvidia,openrouter,groq,ollama,lmstudio

# ========== SOURCE OPTIONS ==========
ENABLE_RSS=true
ENABLE_APIFY_TWITTER=false
ENABLE_APIFY_REDDIT=true
ENABLE_HN=false
ENABLE_ARXIV=false
ENABLE_GITHUB=false
ENABLE_YOUTUBE=true

# ========== YOUTUBE ==========
YOUTUBE_API_KEY=
YOUTUBE_CHANNELS=
YOUTUBE_FETCH_COMMENTS=true
YOUTUBE_MAX_VIDEOS_PER_CHANNEL=5
YOUTUBE_TRANSCRIPT_LANG=en

# Hacker News search tag
HN_TAG=ai

# ========== SETTINGS ==========
FETCH_INTERVAL_MINUTES=45
MIN_RELEVANCE_SCORE=6
BATCH_SIZE=5
MAX_ARTICLES_PER_RUN=5